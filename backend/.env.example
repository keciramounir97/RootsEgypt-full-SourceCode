# Local development example only.
# Production on EasyPanel should inject environment variables at runtime.
# Recommended production contract:
# - DATABASE_URL
# or:
# - DB_HOST
# - DB_PORT
# - DB_USER
# - DB_PASSWORD
# - DB_NAME
# Compatibility aliases also work: MYSQL_URL, MYSQL_URI, DB_URL, MYSQL_*, DATABASE_*.

# ===============================
# SERVER
# ===============================
NODE_ENV=production
PORT=5000
API_URL=https://api.rootsegypt.org
FRONTEND_URL=https://rootsegypt.org

# ===============================
# DATABASE
# ===============================
DB_CLIENT=mysql2
DB_HOST=rootsegypt_database-egyptroots
DB_PORT=3306
DB_NAME=rootsegypt
DB_USER=adminegypt
DB_PASSWORD=admin2025$
MYSQL_HOST=rootsegypt_database-egyptroots
MYSQL_PORT=3306
MYSQL_DATABASE=rootsegypt
MYSQL_USER=adminegypt
MYSQL_PASSWORD=admin2025$
MYSQL_ROOT_PASSWORD=admin2025$
DATABASE_URL=mysql://adminegypt:admin2025%24@rootsegypt_database-egyptroots:3306/rootsegypt
DB_CHARSET=utf8mb4
DB_CONNECTION_LIMIT=10
DB_POOL_TIMEOUT=30
DB_BACKOFF_MS=15000
DB_POOL_BACKOFF_MS=3000

# ===============================
# AUTH (JWT) - Generate a strong secret: openssl rand -hex 64
# ===============================
JWT_SECRET=your-super-secret-jwt-key-at-least-64-chars
JWT_EXPIRES_IN=30d
RESET_CODE_TTL=900
SESSION_TTL_SECONDS=2592000

# ===============================
# CORS - Comma-separated allowed origins
# ===============================
CORS_ORIGIN=https://rootsegypt.org,https://www.rootsegypt.org,https://api.rootsegypt.org,http://localhost:5173,http://localhost:3000

# ===============================
# RATE LIMITING
# ===============================
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# ===============================
# MAIL (SMTP)
# ===============================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=Your App <noreply@example.com>

# ===============================
# APP SETTINGS
# ===============================
SETTINGS_CACHE_TTL_MS=15000
OTP_EXPIRES_MINUTES=10
PASSWORD_RESET_EXPIRES_MINUTES=15
MAX_LOGIN_ATTEMPTS=5

# Auto-run migrations on boot if required tables are missing
AUTO_RUN_MIGRATIONS=true
