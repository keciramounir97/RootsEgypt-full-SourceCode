# ==========================================
# RootsEgypt Backend — Environment Variables
# ==========================================
# Copy this file to .env (dev) or .env.production (staging)
# For EasyPanel: paste these into the backend service → Environment tab
#
# IMPORTANT: EasyPanel runtime env vars ALWAYS override .env files.

# ==========================================
# DATABASE (pick ONE approach)
# ==========================================

# Approach 1: Single connection URL (RECOMMENDED for EasyPanel)
# Copy "Internal Connection URL" from your EasyPanel MySQL service
DATABASE_URL=mysql://adminegypt:YOUR_PASSWORD@rootsegypt_database-egyptroots:3306/rootsegypt

# Approach 2: Individual variables (alternative)
# DB_HOST=rootsegypt_database-egyptroots
# DB_PORT=3306
# DB_USER=adminegypt
# DB_PASSWORD=YOUR_PASSWORD
# DB_NAME=rootsegypt

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=production
PORT=5000

# ==========================================
# JWT / AUTH
# ==========================================
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# ==========================================
# CORS
# ==========================================
FRONTEND_URL=https://rootsegypt.org
API_URL=https://api.rootsegypt.org

# ==========================================
# EMAIL (optional — required for password reset emails)
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_app_password

# ==========================================
# STRICTNESS (optional)
# ==========================================
# DB_STRICT_STARTUP=true   # crash if DB is unreachable on startup (default: false)
