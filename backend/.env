# ===============================
# SERVER
# ===============================
NODE_ENV=development
PORT=5000
API_URL=https://api.rootsegypt.org
FRONTEND_URL=https://rootsegypt.org

# ===============================
# DATABASE
# Use DB_* and keep DATABASE_URL as fallback for container environments.
# ===============================
DB_CLIENT=mysql2
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rootsegypt
DB_USER=adminegypt
DB_PASSWORD=admin2025$
# URL-encoded password to avoid parser/shell issues with special chars
DATABASE_URL=mysql://adminegypt:admin2025$@localhost:3306/rootsegypt
DB_CHARSET=utf8mb4
DB_CONNECTION_LIMIT=5
DB_ACQUIRE_TIMEOUT_MS=15000
DB_IDLE_TIMEOUT_MS=10000

# ===============================
# AUTH (JWT)
# ===============================
JWT_SECRET=d1cb88c3dc305de2f683da0b2174fb18b18be5276b9f44d26487f2d5b34c9bb329644049d51364bf68d80a94eefe708e716277663319b8b7f51bd8590c37d31e
JWT_EXPIRES_IN=30d
RESET_CODE_TTL=900
SESSION_TTL_SECONDS=2592000

# ===============================
# CORS
# ===============================
CORS_ORIGIN=http://localhost:80,http://127.0.0.1:80,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,https://rootsegypt.org,https://www.rootsegypt.org,https://api.rootsegypt.org,https://backend.rootsegypt.org,https://frontend-rootsegypt.easypanel.host
CORS_STRICT=true

# ===============================
# RATE LIMITING
# ===============================
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# ===============================
# MAIL (SMTP) — disabled, admin panel manages users directly
# ===============================
SMTP_ENABLED=false
#SMTP_HOST=
#SMTP_PORT=465
#SMTP_SECURE=true
#SMTP_USER=
#SMTP_PASS=
#EMAIL_FROM=

# ===============================
# APP SETTINGS
# ===============================
SETTINGS_CACHE_TTL_MS=15000
OTP_EXPIRES_MINUTES=10
PASSWORD_RESET_EXPIRES_MINUTES=15
MAX_LOGIN_ATTEMPTS=5

# ===============================
# SEED (dev/bootstrap)
# ===============================
SEED_ADMIN_EMAIL=karimadmin@rootsegypt.org
SEED_ADMIN_PASSWORD=admin2025$
SEED_ADMIN_FULL_NAME=Karim Admin
SEED_ADMIN_ROLE_ID=1
SEED_ADMIN_FORCE=true
